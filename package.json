{
  "name": "@effect-x/ultimate-search",
  "version": "0.1.5",
  "description": "CLI-first web search toolkit and read-only MCP server for agents.",
  "keywords": [
    "agent",
    "cli",
    "effect",
    "grok",
    "mcp",
    "search",
    "tavily"
  ],
  "homepage": "https://github.com/effect-anything/ultimate-search#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/ultimate-search/issues"
  },
  "license": "MIT",
  "contributors": [
    "xesrevinu"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effect-anything/ultimate-search.git"
  },
  "bin": {
    "ultimate-search": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/cli.js",
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "lefthook install && effect-tsgo patch",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@effect/platform-node": "4.0.0-beta.41",
    "@effect/tsgo": "0.0.20",
    "@effect/vitest": "4.0.0-beta.41",
    "effect": "4.0.0-beta.41",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.6",
    "vitest": "^4.1.2"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "@effect/platform-node": "4.0.0-beta.41",
    "@effect/platform-node-shared": "4.0.0-beta.41",
    "detect-libc": "2.1.2",
    "effect": "4.0.0-beta.41",
    "find-my-way-ts": "0.1.6",
    "ini": "6.0.0",
    "msgpackr": "1.11.9",
    "msgpackr-extract": "3.0.3",
    "multipasta": "0.2.7",
    "node-gyp-build-optional-packages": "5.2.2",
    "toml": "3.0.0",
    "yaml": "2.8.2"
  },
  "knip": {
    "ignoreDependencies": [
      "@effect/language-service"
    ]
  }
}
