{
  "name": "ultimate-search",
  "version": "0.0.0",
  "bin": {
    "ultimate-search": "./dist/cli"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "test": "vitest --silent 'passed-only'",
    "madge": "madge --circular --ts-config ./tsconfig.json --no-color --no-spinner --extensions 'ts,tsx' ./src",
    "check": "concurrently \"oxlint\" \"tsgo --noEmit\" \"bun run test --watch false\" \"bun run madge\" \"effect-language-service diagnostics --project tsconfig.json\"",
    "fix": "concurrently \"oxlint --fix\" \"oxfmt\"",
    "build": "bun build --compile --production --sourcemap=inline --outfile=./dist/cli ./src/cli.ts",
    "prepublishOnly": "bun build"
  },
  "devDependencies": {
    "@effect/language-service": "^0.79.0",
    "@effect/platform-bun": "4.0.0-beta.31",
    "@effect/vitest": "4.0.0-beta.31",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "concurrently": "^9.2.1",
    "effect": "4.0.0-beta.31",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "madge": "^8.0.0",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "typescript": "^5.9.3"
  }
}
